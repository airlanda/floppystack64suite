  "scripts": {
    "dev:host": "nx serve host",
    "dev:disks": "nx serve disks",
    "dev:games": "nx serve games",
    "dev:all": "npm run dev:frontend",
    "dev:backend": "nx serve backend",
    "dev:frontend": "nx run-many -t serve -p host,disks,games,play --parallel=4",
    "start-all:dev": "node tools/dev/start-all-dev.js",
    "clean:dev-ports": "node tools/dev/clean-dev-ports.js",
    "start-all:dev:clean": "npm run clean:dev-ports && npm run start-all:dev",
    "dev:mobile": "nx serve mobile",
    "dev:web-legacy": "nx serve web-legacy",
    "dev:mobile:expo": "npm --prefix apps/mobile run start",
    "start-mobile:dev": "node tools/dev/start-mobile-dev.js",
    "start:backend:static": "nx run backend:serve:static-web",
    "build:web-legacy": "nx run web-legacy:check",
    "start:web-legacy:backend": "node tools/dev/start-web-legacy-backend.js",
    "clean:backend-port": "node tools/dev/clean-backend-port.js",
    "start:web-legacy:backend:clean": "npm run clean:backend-port && npm run start:web-legacy:backend",
    "dev:play": "nx serve play",
    "dev:angular-host": "nx serve angular-host",
    "dev:angular-interop": "nx run-many -t serve -p angular-host,disks,games --parallel=3",
    "dev:angular-interop:clean": "npm run clean:dev-ports && npm run dev:angular-interop",
    "dev:angular-shell": "nx serve angular-shell",
    "dev:angular-disks": "nx serve angularDisks",
    "dev:angular-games": "nx serve angularGames",
    "dev:angular-mfes": "nx run-many -t serve -p angular-shell,angularDisks,angularGames --parallel=10",
    "dev:angular-mfes:clean": "npm run clean:dev-ports && npm run dev:angular-mfes"
  },
