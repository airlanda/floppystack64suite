{
  "name": "mobile",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/mobile/src",
  "tags": ["scope:mobile", "type:transitional"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm --prefix apps/mobile run start",
        "cwd": "."
      }
    },
    "check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm --prefix apps/mobile run test:data",
        "cwd": "."
      }
    },
    "check:legacy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm --prefix ../floppystack64/mobile run test:data",
        "cwd": "."
      }
    }
  }
}
