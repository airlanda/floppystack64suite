{
  "name": "web-legacy",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/web-legacy/src",
  "tags": ["scope:web-legacy", "type:transitional"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm --prefix apps/web-legacy run dev",
        "cwd": "."
      }
    },
    "check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm --prefix apps/web-legacy run build",
        "cwd": "."
      }
    },
    "check:legacy": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm --prefix ../floppystack64/client run build",
        "cwd": "."
      }
    }
  }
}
