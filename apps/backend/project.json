{
    "name":  "backend",
    "$schema":  "../../node_modules/nx/schemas/project-schema.json",
    "projectType":  "application",
    "sourceRoot":  "apps/backend",
    "tags":  [
                 "scope:backend",
                 "type:transitional"
             ],
    "targets":  {
                    "serve":  {
                                  "executor":  "nx:run-commands",
                                  "options":  {
                                                  "command":  "nodemon apps/backend/server.js",
                                                  "cwd":  "."
                                              }
                              },
                    "check":  {
                                  "executor":  "nx:run-commands",
                                  "options":  {
                                                  "command":  "node -c apps/backend/server.js",
                                                  "cwd":  "."
                                              }
                              },
                    "check:legacy":  {
                                         "executor":  "nx:run-commands",
                                         "options":  {
                                                         "command":  "node -c ../floppystack64/server.js",
                                                         "cwd":  "."
                                                     }
                                     },
                    "serve:static-web":  {
                                             "executor":  "nx:run-commands",
                                             "options":  {
                                                             "command":  "node apps/backend/server.js",
                                                             "cwd":  "."
                                                         }
                                         }
                }
}
